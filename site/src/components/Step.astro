---
interface Props {
  n: string;
  id: string;
  title: string;
  last?: boolean;
}
const { n, id, title, last = false } = Astro.props;
---

<section class={`step ${last ? 'is-last' : ''}`} id={id} data-step>
  <div class="step-rail" aria-hidden="true">
    <span class="step-num">{n}</span>
  </div>
  <div class="step-content">
    <h2 class="step-title">{title}</h2>
    <div class="step-body"><slot /></div>
  </div>
</section>

<style>
  .step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1rem, 3vw, 2rem);
    padding-bottom: clamp(2.2rem, 5vw, 3.5rem);
  }
  .step-rail { position: relative; display: flex; justify-content: center; }
  .step-rail::after {
    content: '';
    position: absolute;
    top: 2.6rem;
    bottom: -0.5rem;
    width: 1px;
    background: var(--ink-line);
  }
  .is-last .step-rail::after { display: none; }
  .step-num {
    position: sticky;
    top: 5rem;
    width: 2.3rem;
    height: 2.3rem;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--ink);
    background: var(--ember);
    z-index: 1;
  }
  .step-title {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 700;
    margin-top: 0.15rem;
    margin-bottom: 1rem;
    scroll-margin-top: 5rem;
  }
  @media (max-width: 560px) {
    .step { grid-template-columns: auto 1fr; gap: 0.9rem; }
    .step-num { width: 2rem; height: 2rem; font-size: 0.8rem; top: 4.6rem; }
  }
</style>

<style is:global>
  .step-body { color: var(--dawn-dim); font-size: 0.98rem; line-height: 1.7; }
  .step-body > * + * { margin-top: 0.9rem; }
  .step-body strong { color: var(--dawn); font-weight: 600; }
  .step-body a { color: var(--ember); text-decoration: underline; text-underline-offset: 2px; }
  .step-body ol, .step-body ul { padding-left: 1.2rem; display: grid; gap: 0.4rem; }
  .step-body li { padding-left: 0.2rem; }
  .step-body li::marker { color: var(--dawn-faint); }
  .step-body h3 {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ember);
    margin-top: 1.6rem;
  }
  .step-body .cmd-stack { display: grid; gap: 0.55rem; margin-block: 0.4rem; }
</style>
